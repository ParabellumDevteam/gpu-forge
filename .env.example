# GPU Forge configuration

# Your receiving wallet on Polygon (use a dedicated hot wallet, sweep to your Treasury Safe)
PAY_TO=0xYourReceivingWalletHere

# Polygon RPC. Public default works; use Alchemy/Infura for reliability under load.
POLYGON_RPC=https://polygon-rpc.com

# Native USDC on Polygon PoS (default). For bridged USDC.e use 0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

MIN_CONFIRMATIONS=5
PORT=4402
HOST=0.0.0.0
DB_PATH=./forge-ledger.json

# Admin key for GET /v1/revenue
ADMIN_KEY=change-me

# Backends actually running on the GPU
OLLAMA_URL=http://127.0.0.1:11434
DEFAULT_MODEL=llama3.1:8b
WHISPER_BIN=whisper-cli
WHISPER_MODEL=/opt/whisper/ggml-base.bin
COMFY_URL=http://127.0.0.1:8188
# COMFY_WIRED=1

# Gas wallet for standard x402 self-settle (broadcasts transferWithAuthorization on the buyer's chosen rail).
# Fund with a little ETH on Base (~0.0005 covers hundreds of settles). Leave unset to disable the signed-authorization flow.
# SETTLE_PRIVATE_KEY=0x...

# Coinbase CDP API key (portal.cdp.coinbase.com). When set, signed-authorization
# payments settle THROUGH the CDP facilitator (gas sponsored by Coinbase) with
# self-settle as fallback. Required for CDP Bazaar / Agentic.Market listing:
# the Bazaar catalogs a service on its first successful facilitator settle.
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
